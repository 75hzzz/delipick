DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=delipick
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# 쉼표로 구분해 프론트 주소를 넣습니다.
# 예) CORS_ALLOW_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
CORS_ALLOW_ORIGINS=*

# true/false (기본 false). true면 60분마다 배달시간 배치 실행.
ENABLE_DELIVERY_WORKER=false

NAVER_CLIENT_ID=naver_client_id
NAVER_CLIENT_SECRET=naver_client_secret

WEATHER_API_KEY=weather_api_key

OPENAI_API_KEY=openai_api_key
OPENAI_MODEL=gpt-4o-mini
