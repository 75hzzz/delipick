DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=delipick
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Comma-separated frontend origins (쉼표로 구분해 프론트엔드 주소 넣기)
# Example: CORS_ALLOW_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
CORS_ALLOW_ORIGINS=*

# true/false (default false). If true, refresh delivery times every 60 minutes
ENABLE_DELIVERY_WORKER=false

NAVER_CLIENT_ID=naver_client_id
NAVER_CLIENT_SECRET=naver_client_secret

OPENAI_API_KEY=openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ENABLE_TASTE_LLM=false
MENU_FLAVOR_MODEL=gpt-4o-mini

# Local path for scripts/generate_menu_flavors_from_nutrient_db.py
# Download source: https://various.foodsafetykorea.go.kr/nutrient/general/down/historyList.do
FOOD_DB_PATH=C:\path\to\식품성분표(10개정판).xlsx
FOOD_DB_SHEET=국가표준식품성분 Database 10.3
