DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=delipick
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# 프론트엔드에서 API를 호출할 수 있도록 허용할 Origin 목록
# 현재는 *로 사용해도 무방
CORS_ALLOW_ORIGINS=*

# true/false (기본 false)
# true로 설정하면 60분마다 배달시간 갱신 배치를 실행
ENABLE_DELIVERY_WORKER=false

NAVER_CLIENT_ID=naver_client_id
NAVER_CLIENT_SECRET=naver_client_secret

WEATHER_API_KEY=weather_api_key

OPENAI_API_KEY=openai_api_key
OPENAI_MODEL=gpt-4o-mini

# =========================
# LLM/매운맛 튜닝 파라미터
# =========================
# 아래 점수값은 0~100 범위
# 값이 높을수록 후보가 더 엄격하게 걸러짐.

# 취향 필터(맵기/날씨) ON일 때 기본 LLM 최소 점수
LLM_FILTER_MIN_SCORE=60

# 매운맛 선택 시 사용하는 LLM 최소 점수
# 높이면 매운맛 후보가 더 줄고, 낮추면 후보 수가 늘어남.
LLM_SPICY_MIN_SCORE=64

# 순한맛 선택 시 사용하는 LLM 최소 점수
# 너무 높이면 순한맛 결과가 적어질 수 있음.
LLM_MILD_MIN_SCORE=52

# 취향 필터 적용 시 목표 최소 결과 수
# 기준 미달 시 컷오프를 단계적으로 완화해 이 수치에 맞추려 시도
LLM_MIN_RESULTS=10

# 매운맛 전용 "강한 시그니처" 기준 (1차 필터)
# 매운 브랜드/매운 메뉴 비율/매운 대표메뉴 힌트를 종합한 점수 기준
HOT_SIGNATURE_STRICT_MIN=0.85

# 매운맛 후보가 부족할 때 적용하는 완화 기준 (2차 필터)
HOT_SIGNATURE_RELAXED_MIN=0.40

# 그래도 결과가 적을 때 차선 후보를 보충하는 최종 기준
HOT_SIGNATURE_FALLBACK_MIN=0.25
